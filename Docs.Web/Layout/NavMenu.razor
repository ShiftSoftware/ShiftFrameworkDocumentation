@using MudBlazor
@using Microsoft.AspNetCore.Components.Routing
@using Docs.Web.Services

@implements IDisposable
@inject NavigationManager NavigationManager
@inject SearchService Search

@*
    NavMenu — data-driven nav. Reads wwwroot/search-index.json (built by
    Docs.SnippetGen from <DocPageMeta /> declarations on every doc page) and
    renders pages grouped by Section. New pages auto-appear here just by
    declaring DocPageMeta — no nav editing per page.

    Sections are rendered in the order declared by SectionOrder below.
    Anything else falls under "Other".
*@

<MudNavMenu Color="Color.Warning">
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>

    @if (_groups is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else
    {
        @foreach (var grp in _groups)
        {
            <MudNavGroup Title="@grp.Section" Expanded="@(IsActive(SectionToHrefPrefix(grp.Section)))">
                @foreach (var entry in grp.Pages)
                {
                    <MudNavLink Href="@entry.Url" Match="NavLinkMatch.All">
                        @if (entry.Status == "Draft")
                        {
                            <MudTooltip Text="Draft — work in progress">
                                <span class="nav-status-dot nav-status-draft"></span>
                            </MudTooltip>
                        }
                        else if (entry.Status == "Reviewed")
                        {
                            <MudTooltip Text="Reviewed — content complete">
                                <span class="nav-status-dot nav-status-reviewed"></span>
                            </MudTooltip>
                        }
                        @entry.Title
                    </MudNavLink>
                }
            </MudNavGroup>
        }
    }
</MudNavMenu>

@code {
    // The five-section taxonomy from PLAN.md. Sections render in this order;
    // anything else falls into a tail group.
    private static readonly IReadOnlyList<string> SectionOrder = new[]
    {
        "Get Started",
        "Concepts",
        "Guides",
        "Components",
        "API Reference",
    };

    private IReadOnlyList<(string Section, IReadOnlyList<SearchEntry> Pages)>? _groups;

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        _groups = await Search.GetAllGroupedBySectionAsync(SectionOrder);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private bool IsActive(string href)
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimEnd('/');
        return relativePath.StartsWith(href.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }

    // Map a section name to its expected URL prefix so the group auto-expands
    // when the user is browsing inside it. Convention: lowercase, spaces → dashes.
    private static string SectionToHrefPrefix(string section) =>
        "/" + section.ToLowerInvariant().Replace(' ', '-');

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
