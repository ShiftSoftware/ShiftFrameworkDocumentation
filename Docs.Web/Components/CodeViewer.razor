@using MudBlazor;

@if (file is null)
{
    <div style="display: flex; align-items: center; justify-content: center;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
     </div>
}
else
{
    <pre data-line="@file.Linehighlight" class="line-numbers"><code class="@file.PrismClass">@file.Content</code></pre>
}   
